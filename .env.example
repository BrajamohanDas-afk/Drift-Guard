DATABASE_URL=postgresql+asyncpg://drift:drift@postgres:5432/driftguard
ALEMBIC_DATABASE_URL=postgresql+psycopg2://drift:drift@localhost:5432/driftguard
REDIS_URL=redis://redis:6379
SECRET_KEY=your-secret-key-here
GITHUB_TOKEN=your-github-token-here
SQL_ECHO=false
API_KEY=change-me

# Optional: PagerDuty collector token
# - Leave empty for local development (collector returns structured "not configured")
# - Unit tests use mocked responses and do not require live PagerDuty credentials
# - Required only for production/live drift detection against PagerDuty
# - Get token after signup: https://www.pagerduty.com/sign-up/
PAGERDUTY_API_TOKEN=

# Optional: Kubernetes collector configuration
# - Leave empty for local development/testing if not using live cluster checks
KUBERNETES_API_URL=
KUBERNETES_BEARER_TOKEN=
KUBERNETES_VERIFY_SSL=true
